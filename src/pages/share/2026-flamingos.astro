---
import BaseLayout from '../../layouts/BaseLayout.astro'

const youtubeId = '71FvzzR2uwE'
const embedUrl = `https://www.youtube-nocookie.com/embed/${youtubeId}?rel=0`
---

<BaseLayout
	title="Flamingos"
	description="Watch the game footage."
	image="/flamingos-2026-og.jpg"
	hideFooter
>
	<main class="app-container pt-24">
		<h1 class="text-6xl pb-2 font-bold">Flamingos</h1>
		<p class="text-lg text-neutral-600 dark:text-neutral-400">
			Spring 2026 Championship Game
		</p>
	</main>

	<section class="app-container pt-12 pb-6">
		<div
			class="relative w-full rounded-xl overflow-hidden bg-black shadow-lg"
			style="aspect-ratio: 16 / 9;"
		>
			<iframe
				class="absolute inset-0 w-full h-full"
				src={embedUrl}
				title="Flamingos"
				frameborder="0"
				allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
				referrerpolicy="strict-origin-when-cross-origin"
				allowfullscreen
			></iframe>
		</div>

	</section>

	<section class="app-container pb-12">
		<div
			class="rounded-xl border border-neutral-200 dark:border-neutral-800 bg-neutral-50 dark:bg-neutral-900/40 p-8 md:p-10"
		>
			<div
				class="flex flex-col md:flex-row md:items-center md:justify-between gap-6"
			>
				<div>
					<p
						class="text-xs font-semibold uppercase tracking-widest text-neutral-500 dark:text-neutral-400 mb-3"
					>
						Built for Engineers who Ship
					</p>
					<a
						href="https://wallfacer.ai"
						target="_blank"
						rel="noopener noreferrer"
						class="inline-flex items-center gap-3 text-2xl font-bold tracking-tight text-neutral-900 dark:text-neutral-100 hover:opacity-80 transition-opacity"
					>
						<img
							src="/wallfacer-icon-black.png"
							alt=""
							width="40"
							height="40"
							class="w-10 h-10 block dark:hidden"
						/>
						<img
							src="/wallfacer-icon-white.png"
							alt=""
							width="40"
							height="40"
							class="w-10 h-10 hidden dark:block"
						/>
						Wallfacer
					</a>
					<p
						class="mt-2 text-neutral-600 dark:text-neutral-400 text-base md:text-lg"
					>
						Watch the agent build. Ship from anywhere.
					</p>
					<p
						class="mt-3 text-neutral-600 dark:text-neutral-400 text-sm md:text-base max-w-2xl"
					>
						Wallfacer runs Claude and Codex inside a real cloud dev environment
						with your repo, services, Docker, Xcode, and the iOS
						Simulator. Chat, diffs, and live preview all live in one
						task you can open from any device.
					</p>
				</div>
				<div class="flex flex-col items-center gap-2">
					<a
						href="https://wallfacer.ai"
						target="_blank"
						rel="noopener noreferrer"
						class="inline-flex items-center justify-center whitespace-nowrap px-8 py-3 rounded-lg bg-neutral-900 text-white hover:bg-neutral-700 dark:bg-white dark:text-neutral-900 dark:hover:bg-neutral-200 transition-colors font-medium text-sm shrink-0"
					>
						Learn more
					</a>
					<a
						href="https://wallfacer.ai"
						target="_blank"
						rel="noopener noreferrer"
						class="text-sm text-neutral-500 dark:text-neutral-400 hover:text-neutral-900 dark:hover:text-neutral-100 transition-colors"
					>
						https://wallfacer.ai
					</a>
				</div>
			</div>
		</div>
	</section>
</BaseLayout>
