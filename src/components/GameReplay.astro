									<th class="text-left font-semibold pr-3 py-1">
										Lineup
									</th>
									<th class="text-center font-semibold px-2 py-1">
										AB
									</th>
									<th class="text-center font-semibold px-2 py-1">
										R
									</th>
									<th class="text-center font-semibold px-2 py-1">
										H
									</th>
									<th class="text-center font-semibold px-2 py-1">
										RBI
									</th>
									<th class="text-center font-semibold px-2 py-1">
										BB
									</th>
									<th class="text-center font-semibold px-2 py-1">
										SO
									</th>
								</tr>
							</thead>
							<tbody>
								{batters.lineup.map((b) => (
									<tr class="border-t border-neutral-100 dark:border-neutral-800">
										<td class="text-left py-1.5 pr-3 text-neutral-900 dark:text-neutral-100">
											{b.name}
										</td>
										<td class="text-center px-2 py-1.5">{b.AB}</td>
										<td class="text-center px-2 py-1.5">{b.R}</td>
										<td class="text-center px-2 py-1.5">{b.H}</td>
										<td class="text-center px-2 py-1.5">{b.RBI}</td>
										<td class="text-center px-2 py-1.5">{b.BB}</td>
										<td class="text-center px-2 py-1.5">{b.SO}</td>
									</tr>
								))}
								<tr class="border-t border-neutral-200 dark:border-neutral-700 font-semibold">
									<td class="text-left py-2 pr-3">TEAM</td>
									<td class="text-center px-2 py-2">{batters.totals.AB}</td>
									<td class="text-center px-2 py-2">{batters.totals.R}</td>
									<td class="text-center px-2 py-2">{batters.totals.H}</td>
									<td class="text-center px-2 py-2">{batters.totals.RBI}</td>
									<td class="text-center px-2 py-2">{batters.totals.BB}</td>
									<td class="text-center px-2 py-2">{batters.totals.SO}</td>
								</tr>
							</tbody>
						</table>
					</div>
					<div class="px-4 sm:px-6 pb-5 overflow-x-auto">
						<table class="w-full text-sm tabular-nums">
							<thead>
								<tr class="text-xs text-neutral-500 dark:text-neutral-400">
									<th class="text-left font-semibold pr-3 py-1">
										Pitching
									</th>
									<th class="text-center font-semibold px-2 py-1">
										IP
									</th>
									<th class="text-center font-semibold px-2 py-1">
										H
									</th>
									<th class="text-center font-semibold px-2 py-1">
										R
									</th>
									<th class="text-center font-semibold px-2 py-1">
										BB
									</th>
									<th class="text-center font-semibold px-2 py-1">
										SO
									</th>
								</tr>
							</thead>
							<tbody>
								{pitchers.pitchers.map((p) => (
									<tr class="border-t border-neutral-100 dark:border-neutral-800">
										<td class="text-left py-1.5 pr-3 text-neutral-900 dark:text-neutral-100">
											{p.name}
										</td>
										<td class="text-center px-2 py-1.5">{formatIP(p.outs)}</td>
										<td class="text-center px-2 py-1.5">{p.H}</td>
										<td class="text-center px-2 py-1.5">{p.R}</td>
										<td class="text-center px-2 py-1.5">{p.BB}</td>
										<td class="text-center px-2 py-1.5">{p.SO}</td>
									</tr>
								))}
								<tr class="border-t border-neutral-200 dark:border-neutral-700 font-semibold">
									<td class="text-left py-2 pr-3">TEAM</td>
									<td class="text-center px-2 py-2">{formatIP(pitchers.totals.outs)}</td>
									<td class="text-center px-2 py-2">{pitchers.totals.H}</td>
									<td class="text-center px-2 py-2">{pitchers.totals.R}</td>
									<td class="text-center px-2 py-2">{pitchers.totals.BB}</td>
									<td class="text-center px-2 py-2">{pitchers.totals.SO}</td>
								</tr>
							</tbody>
						</table>
					</div>
				</div>
			))
		}
	</div>
</section>

<script>
	interface Play {
		inning: number
		half: 'top' | 'bottom'
		batter: string
		result: string
		summary: string
		outs: number
		runs: number
		bases: [boolean, boolean, boolean]
		away: number
		home: number
		scorers?: string[]
	}

	interface GameData {
		innings: number
		awayTeam: string
		homeTeam: string
		plays: Play[]
	}

	const FLM_COLOR = '#ec4899' // pink-500
	const SRP_COLOR = '#14b8a6' // teal-500

	const root = document.getElementById('game-replay') as HTMLElement
	const game: GameData = JSON.parse(root.dataset.game!)
	const plays = game.plays
	const total = plays.length

	let idx = 0
	let playing = false
	let timer: number | null = null
	const TICK_MS = 2500

	const $ = <T extends Element = Element>(sel: string) =>
		root.querySelector(sel) as T

	const resultLabels: Record<string, string> = {
		walk: 'Walk',
		single: 'Single',
		double: 'Double',
		triple: 'Triple',
		home_run: 'Home Run',
		strikeout: 'Strikeout',
		groundout: 'Ground Out',
		flyout: 'Fly Out',
		popout: 'Pop Out',
		doubleplay: 'Double Play',
		caught_stealing: 'Caught Stealing',
		inning_ended: 'Inning Ended',
	}

	const ordinal = (n: number) =>
		n === 1 ? '1st' : n === 2 ? '2nd' : n === 3 ? '3rd' : `${n}th`

	function pitcherFor(p: Play): string {
		if (p.half === 'top') {
			if (p.inning === 1) return 'Brady Dunn'
			if (p.inning === 2)
				return p.batter === 'Henry G' ? 'Corbin Levac' : 'Brady Dunn'
			if (p.inning <= 5) return 'Corbin Levac'
			return p.batter === 'Byron M' || p.batter === 'Henry G (at-bat)'
				? 'Owen Lane'
				: 'Corbin Levac'
		}
		if (p.inning <= 3) return 'Beckham H'
		if (p.inning === 4) return 'Andrew M'
		return 'Jackson C'
	}

	function computeLines(upTo: number) {
		const away: (number | string)[] = Array(game.innings).fill('-')
		const home: (number | string)[] = Array(game.innings).fill('-')
		for (let i = 0; i <= upTo; i++) {
			const p = plays[i]
			const arr = p.half === 'top' ? away : home
			const cell = arr[p.inning - 1]
			arr[p.inning - 1] = (typeof cell === 'number' ? cell : 0) + p.runs
		}
		return { away, home }
	}

	function render() {
		const p = plays[idx]
		const battingAway = p.half === 'top'
		const teamColor = battingAway ? SRP_COLOR : FLM_COLOR

		// Score bar
		$('#score-away').textContent = String(p.away)
		$('#score-home').textContent = String(p.home)
		$('#play-half-inning').textContent =
			`${battingAway ? 'Top' : 'Bottom'} ${ordinal(p.inning)}`
		;($('[data-batting-dot="away"]') as HTMLElement).style.opacity =
			battingAway ? '1' : '0'
		;($('[data-batting-dot="home"]') as HTMLElement).style.opacity =
			battingAway ? '0' : '1'

		// Pitching / batting cards
		const pitcher = pitcherFor(p)
		$('#pitcher-name').textContent = pitcher
		$('#batter-name').textContent = p.batter
		$('#pitching-team').textContent = battingAway
			? game.homeTeam
			: game.awayTeam
		$('#batting-team').textContent = battingAway
			? game.awayTeam
			: game.homeTeam

		// Pills on the field
		$('#pitcher-pill').textContent = pitcher
		$('#batter-pill').textContent = p.batter
		;($('#batter-pill') as HTMLElement).style.backgroundColor = teamColor

		// Scoreboard cells
		const lines = computeLines(idx)
		for (let i = 1; i <= game.innings; i++) {
			const aCell = $(`[data-inning-cell="away-${i}"]`)
			const hCell = $(`[data-inning-cell="home-${i}"]`)
			if (aCell) aCell.textContent = String(lines.away[i - 1])
			if (hCell) hCell.textContent = String(lines.home[i - 1])
		}
		$('[data-total="away-R"]').textContent = String(p.away)
		$('[data-total="home-R"]').textContent = String(p.home)

		// Highlight current inning column
		root.querySelectorAll('[data-inning-col]').forEach((el) => {
			const inn = Number((el as HTMLElement).dataset.inningCol)
			const active = inn === p.inning
			el.classList.toggle('text-pink-600', active && !battingAway)
			el.classList.toggle('dark:text-pink-400', active && !battingAway)
			el.classList.toggle('text-teal-600', active && battingAway)
			el.classList.toggle('dark:text-teal-400', active && battingAway)
		})

		// Highlight active team row in scoreboard
		const awayRow = $('[data-team="away"]') as HTMLElement
		const homeRow = $('[data-team="home"]') as HTMLElement
		awayRow.classList.toggle('bg-teal-50', battingAway)
		awayRow.classList.toggle('dark:bg-teal-950/30', battingAway)
		homeRow.classList.toggle('bg-pink-50', !battingAway)
		homeRow.classList.toggle('dark:bg-pink-950/30', !battingAway)

		// Runners — fill color matches batting team
		for (let b = 1; b <= 3; b++) {
			const runner = $(`[data-runner="${b}"]`) as SVGElement
			if (runner) {
				runner.setAttribute('opacity', p.bases[b - 1] ? '1' : '0')
				runner.setAttribute('fill', teamColor)
			}
		}

		// Outs — color matches batting team
		for (let o = 1; o <= 3; o++) {
			const dot = $(`[data-out="${o}"]`) as HTMLElement
			const filled = o <= p.outs
			dot.style.backgroundColor = filled ? teamColor : ''
			dot.style.borderColor = filled ? teamColor : ''
		}

		// Play summary
		$('#play-result').textContent = resultLabels[p.result] ?? p.result
		$('#play-summary').textContent = p.summary
		$('#play-counter').textContent = `Play ${idx + 1} of ${total}`

		// Controls
		;($('#play-prev') as HTMLButtonElement).disabled = idx === 0
		;($('#play-next') as HTMLButtonElement).disabled = idx === total - 1

		if (idx === total - 1 && playing) stop()
	}

	function jumpTo(i: number) {
		if (i < 0 || i >= total) return
		idx = i
		render()
	}

	function next() {
		if (idx < total - 1) jumpTo(idx + 1)
	}

	function prev() {
		if (idx > 0) jumpTo(idx - 1)
	}

	function start() {
		if (playing) return
		playing = true
		$('#play-icon').classList.add('hidden')
		$('#pause-icon').classList.remove('hidden')
		;($('#play-toggle') as HTMLElement).setAttribute('aria-label', 'Pause')
		timer = window.setInterval(() => {
			if (idx < total - 1) {
				idx++
				render()
			} else {
				stop()
			}
		}, TICK_MS)
	}

	function stop() {
		playing = false
		if (timer != null) {
			window.clearInterval(timer)
			timer = null
		}
		$('#play-icon').classList.remove('hidden')
		$('#pause-icon').classList.add('hidden')
		;($('#play-toggle') as HTMLElement).setAttribute('aria-label', 'Play')
	}

	function escapeHtml(s: string): string {
		const div = document.createElement('div')
		div.textContent = s
		return div.innerHTML
	}

	// --- Tabs ---
	const tabs = Array.from(
		root.querySelectorAll<HTMLElement>('[data-tab]')
	)
	const panels = Array.from(
		root.querySelectorAll<HTMLElement>('[data-panel]')
	)

	function activateTab(name: string) {
		tabs.forEach((t) => {
			const active = t.dataset.tab === name
			t.setAttribute('aria-selected', active ? 'true' : 'false')
			t.classList.toggle('border-pink-500', active)
			t.classList.toggle('border-transparent', !active)
			t.classList.toggle('text-pink-600', active)
			t.classList.toggle('dark:text-pink-400', active)
			t.classList.toggle('text-neutral-500', !active)
			t.classList.toggle('dark:text-neutral-400', !active)
		})
		panels.forEach((p) => {
			p.classList.toggle('hidden', p.dataset.panel !== name)
		})
	}

	tabs.forEach((t) => {
		t.addEventListener('click', () => activateTab(t.dataset.tab!))
	})

	// --- Search ---
	const searchInput = $('#player-search') as HTMLInputElement
	const searchResults = $('#search-results') as HTMLElement

	function runSearch() {
		const q = searchInput.value.trim().toLowerCase()
		if (q.length < 2) {
			searchResults.classList.add('hidden')
			searchResults.innerHTML = ''
			return
		}
		const matches: { i: number; p: Play }[] = []
		for (let i = 0; i < plays.length; i++) {
			const p = plays[i]
			const haystack =
				`${p.batter} ${p.summary} ${pitcherFor(p)} ${(p.scorers ?? []).join(' ')}`.toLowerCase()
			if (haystack.includes(q)) matches.push({ i, p })
			if (matches.length >= 30) break
		}
		if (matches.length === 0) {
			searchResults.innerHTML = `<li class="px-3 py-2 text-sm text-neutral-500 dark:text-neutral-400">No plays match &ldquo;${escapeHtml(q)}&rdquo;.</li>`
		} else {
			searchResults.innerHTML = matches
				.map(({ i, p }) => {
					const half = p.half === 'top' ? 'Top' : 'Bot'
					const label = resultLabels[p.result] ?? p.result
					return `<li>
						<button type="button" data-jump-to="${i}" class="w-full text-left px-3 py-2 hover:bg-neutral-100 dark:hover:bg-neutral-800 transition-colors border-b border-neutral-100 dark:border-neutral-800 last:border-b-0">
							<div class="flex items-center justify-between gap-2 text-xs text-neutral-500 dark:text-neutral-400">
								<span class="font-semibold">${escapeHtml(p.batter)}</span>
								<span class="tabular-nums">${half} ${p.inning} • ${label}</span>
							</div>
							<p class="mt-0.5 text-sm text-neutral-700 dark:text-neutral-300 leading-snug">${escapeHtml(p.summary)}</p>
						</button>
					</li>`
				})
				.join('')
		}
		searchResults.classList.remove('hidden')
	}

	searchInput.addEventListener('input', runSearch)
	searchInput.addEventListener('focus', () => {
		if (searchInput.value.trim().length >= 2) runSearch()
	})

	searchResults.addEventListener('click', (e) => {
		const btn = (e.target as HTMLElement).closest('[data-jump-to]')
		if (!btn) return
		const i = Number(btn.getAttribute('data-jump-to'))
		stop()
		activateTab('replay')
		jumpTo(i)
		searchResults.classList.add('hidden')
		searchInput.value = ''
		searchInput.blur()
		root.scrollIntoView({ behavior: 'smooth', block: 'start' })
	})

	document.addEventListener('click', (e) => {
		const target = e.target as HTMLElement
		if (
			!searchInput.contains(target) &&
			!searchResults.contains(target)
		) {
			searchResults.classList.add('hidden')
		}
	})

	$('#play-prev').addEventListener('click', () => {
		stop()
		prev()
	})
	$('#play-next').addEventListener('click', () => {
		stop()
		next()
	})
	$('#play-toggle').addEventListener('click', () => {
		playing ? stop() : start()
	})

	render()
</script>
