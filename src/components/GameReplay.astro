	{/* Box Score panel */}
	<div data-panel="boxscore" class="hidden">
		{
			[
				{ team: game.awayTeam, batters: serpientesBatting, pitchers: serpientesPitching },
				{ team: game.homeTeam, batters: flamingosBatting, pitchers: flamingosPitching },
			].map(({ team, batters, pitchers }) => (
				<div class="border-b border-neutral-200 dark:border-neutral-800 last:border-b-0">
					<div class="px-4 sm:px-6 py-3 bg-neutral-50 dark:bg-neutral-800/50">
						<p class="text-xs font-semibold uppercase tracking-widest text-neutral-700 dark:text-neutral-200">
							{team}
						</p>
					</div>
					<div class="px-4 sm:px-6 py-4 overflow-x-auto">
						<table class="w-full text-sm tabular-nums">
							<thead>
								<tr class="text-xs text-neutral-500 dark:text-neutral-400">
									<th class="text-left font-semibold pr-3 py-1">
