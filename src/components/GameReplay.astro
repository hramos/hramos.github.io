							<tbody>
								{batters.lineup.map((b) => (
									<tr class="border-t border-neutral-100 dark:border-neutral-800">
										<td class="text-left py-1.5 pr-3 text-neutral-900 dark:text-neutral-100">
											{b.name}
										</td>
										<td class="text-center px-2 py-1.5">{b.AB}</td>
										<td class="text-center px-2 py-1.5">{b.R}</td>
										<td class="text-center px-2 py-1.5">{b.H}</td>
										<td class="text-center px-2 py-1.5">{b.RBI}</td>
										<td class="text-center px-2 py-1.5">{b.BB}</td>
										<td class="text-center px-2 py-1.5">{b.SO}</td>
									</tr>
								))}
								<tr class="border-t border-neutral-200 dark:border-neutral-700 font-semibold">
									<td class="text-left py-2 pr-3">TEAM</td>
									<td class="text-center px-2 py-2">{batters.totals.AB}</td>
									<td class="text-center px-2 py-2">{batters.totals.R}</td>
									<td class="text-center px-2 py-2">{batters.totals.H}</td>
									<td class="text-center px-2 py-2">{batters.totals.RBI}</td>
									<td class="text-center px-2 py-2">{batters.totals.BB}</td>
									<td class="text-center px-2 py-2">{batters.totals.SO}</td>
