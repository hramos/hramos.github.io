import { game, type Play } from '../data/flamingos-game'

const gameJson = JSON.stringify(game)
const innings = Array.from({ length: game.innings }, (_, i) => i + 1)

// ---- Box-score derivation (static for the whole game) ----

function pitcherForPlay(p: Play): string {
	if (p.half === 'top') {
		if (p.inning === 1) return 'Brady Dunn'
		if (p.inning === 2)
			return p.batter === 'Henry G' ? 'Corbin Levac' : 'Brady Dunn'
		if (p.inning <= 5) return 'Corbin Levac'
		return p.batter === 'Byron M' || p.batter === 'Henry G (at-bat)'
			? 'Owen Lane'
			: 'Corbin Levac'
	}
	if (p.inning <= 3) return 'Beckham H'
	if (p.inning === 4) return 'Andrew M'
	return 'Jackson C'
}

const HIT_RESULTS = ['single', 'double', 'triple', 'home_run']
const AB_RESULTS = [
	'single',
	'double',
	'triple',
	'home_run',
	'strikeout',
	'groundout',
	'flyout',
	'popout',
	'doubleplay',
]

function rbiFor(p: Play): number {
	if (p.runs === 0) return 0
	const s = p.summary.toLowerCase()
	if (
		s.includes('passed ball') ||
		s.includes('steal home') ||
		s.includes('stole home') ||
		s.includes('on error')
	)
		return 0
	if (HIT_RESULTS.includes(p.result)) return p.runs
	if (
		p.result === 'walk' &&
		p.bases[0] &&
		p.bases[1] &&
		p.bases[2]
	)
		return p.runs
	if (['groundout', 'flyout', 'popout', 'doubleplay'].includes(p.result))
		return p.runs
	return 0
}

interface BatterStats {
	name: string
	AB: number
	R: number
	H: number
	RBI: number
	BB: number
	SO: number
}

interface PitcherStats {
	name: string
	outs: number
	H: number
	R: number
	BB: number
	SO: number
}

function computeBatters(side: 'top' | 'bottom'): {
	lineup: BatterStats[]
	totals: BatterStats
} {
	const stats = new Map<string, BatterStats>()
	const order: string[] = []
	const init = (name: string): BatterStats => {
		if (!stats.has(name)) {
			stats.set(name, {
				name,
				AB: 0,
				R: 0,
				H: 0,
				RBI: 0,
				BB: 0,
				SO: 0,
			})
			order.push(name)
		}
		return stats.get(name)!
	}
	for (const p of game.plays) {
		if (
			p.half === side &&
			!p.batter.includes('(running)') &&
			!p.batter.includes('(at-bat)')
		) {
			const s = init(p.batter)
			if (AB_RESULTS.includes(p.result)) s.AB++
			if (HIT_RESULTS.includes(p.result)) s.H++
			if (p.result === 'walk') s.BB++
			if (p.result === 'strikeout') s.SO++
			s.RBI += rbiFor(p)
		}
		if (p.scorers && p.half === side) {
			for (const scorer of p.scorers) init(scorer).R++
		}
	}
	const lineup = order.map((n) => stats.get(n)!)
	const totals: BatterStats = {
		name: 'TEAM',
		AB: 0,
		R: 0,
		H: 0,
		RBI: 0,
		BB: 0,
		SO: 0,
	}
	for (const s of lineup) {
		totals.AB += s.AB
		totals.R += s.R
		totals.H += s.H
		totals.RBI += s.RBI
		totals.BB += s.BB
		totals.SO += s.SO
	}
	return { lineup, totals }
}

function computePitchers(side: 'top' | 'bottom'): {
	pitchers: PitcherStats[]
	totals: PitcherStats
} {
	const stats = new Map<string, PitcherStats>()
	const order: string[] = []
	for (let i = 0; i < game.plays.length; i++) {
		const p = game.plays[i]
		if (p.half !== side) continue
		const pitcher = pitcherForPlay(p)
		if (!stats.has(pitcher)) {
			stats.set(pitcher, {
				name: pitcher,
				outs: 0,
				H: 0,
				R: 0,
				BB: 0,
				SO: 0,
			})
			order.push(pitcher)
		}
		const s = stats.get(pitcher)!
		const prev = i > 0 ? game.plays[i - 1] : null
		const sameHalf =
			prev !== null && prev.half === p.half && prev.inning === p.inning
		const prevOuts = sameHalf ? prev!.outs : 0
		s.outs += p.outs - prevOuts
		s.R += p.runs
		if (HIT_RESULTS.includes(p.result)) s.H++
		if (p.result === 'walk') s.BB++
		if (p.result === 'strikeout') s.SO++
	}
	const pitchers = order.map((n) => stats.get(n)!)
	const totals: PitcherStats = {
		name: 'TEAM',
		outs: 0,
		H: 0,
		R: 0,
		BB: 0,
		SO: 0,
	}
	for (const s of pitchers) {
		totals.outs += s.outs
		totals.H += s.H
		totals.R += s.R
		totals.BB += s.BB
		totals.SO += s.SO
	}
	return { pitchers, totals }
}

function formatIP(outs: number): string {
	return `${Math.floor(outs / 3)}.${outs % 3}`
}

// Away (Serpientes) bats top, pitches bottom.
const serpientesBatting = computeBatters('top')
const flamingosBatting = computeBatters('bottom')
const serpientesPitching = computePitchers('bottom') // SRP pitches when FLM bats
const flamingosPitching = computePitchers('top') // FLM pitches when SRP bats
